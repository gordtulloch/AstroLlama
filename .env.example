# Copy this file to .env and adjust values as needed.

# Base URL of the running llama-server (llama.cpp)
LLAMA_SERVER_URL=http://127.0.0.1:8081

# MCP server endpoint
MCP_SERVER_URL=https://soleilesb.sunrisesd.ca:8001

# Host and port the FastAPI app listens on (127.0.0.1 keeps it local-only)
APP_HOST=127.0.0.1
APP_PORT=8080

# Default system prompt prepended to all conversations (leave empty for none)
DEFAULT_SYSTEM_PROMPT=

# Generation defaults
DEFAULT_MAX_TOKENS=1024
DEFAULT_CONTEXT_SIZE=4096

# ChromaDB / RAG
CHROMA_DB_PATH=data/chromadb
CHROMA_COLLECTION=documents
EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_TOP_K=3
RAG_ENABLED=true
MCP_ENABLED=true

# Microsoft Entra authentication
# Set ENTRA_AUTH_ENABLED=true after you configure app registrations.
ENTRA_AUTH_ENABLED=false
ENTRA_TENANT_ID=
ENTRA_SPA_CLIENT_ID=
ENTRA_API_CLIENT_ID=
ENTRA_API_SCOPE=
ENTRA_REDIRECT_URI=http://127.0.0.1:8080

# Mapping:
# ENTRA_TENANT_ID      -> Entra ID > Overview > Tenant ID
# ENTRA_SPA_CLIENT_ID  -> SPA app registration > Overview > Application (client) ID
# ENTRA_API_CLIENT_ID  -> API app registration > Overview > Application (client) ID
# ENTRA_API_SCOPE      -> API app registration > Expose an API > Scope
#                         Example: api://<ENTRA_API_CLIENT_ID>/access_as_user
# ENTRA_REDIRECT_URI   -> SPA app registration > Authentication > Single-page application redirect URI
# Client secret values are NOT used by this local SPA + token-validation flow.

# LLama.CPP paths for launcher scripts
LLAMA_CPP_PATH=
MODEL_PATH=
